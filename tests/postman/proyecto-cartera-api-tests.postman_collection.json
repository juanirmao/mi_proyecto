{
  "info": {
    "name": "Proyecto Cartera API Tests",
    "description": "Suite de pruebas para API REST del Proyecto Cartera",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Municipios",
      "item": [
        {
          "name": "GET All Municipios",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/municipios",
              "host": ["{{baseUrl}}"],
              "path": ["api", "municipios"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response should be array', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each municipio should have required fields', function () {",
                  "    const jsonData = pm.response.json();",
                  "    jsonData.forEach(municipio => {",
                  "        pm.expect(municipio).to.have.property('id');",
                  "        pm.expect(municipio).to.have.property('nombre');",
                  "        pm.expect(municipio).to.have.property('codigo');",
                  "        pm.expect(municipio).to.have.property('departamento');",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST Create Municipio",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Test Municipio\",\n  \"codigo\": \"TEST001\",\n  \"departamento\": \"Test Departamento\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/municipios",
              "host": ["{{baseUrl}}"],
              "path": ["api", "municipios"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has created municipio data', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData.nombre).to.eql('Test Municipio');",
                  "    pm.expect(jsonData.codigo).to.eql('TEST001');",
                  "});",
                  "",
                  "// Store ID for subsequent tests",
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('testMunicipioId', jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "PUT Update Municipio",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Updated Test Municipio\",\n  \"codigo\": \"TEST001\",\n  \"departamento\": \"Updated Departamento\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/municipios/{{testMunicipioId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "municipios", "{{testMunicipioId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Municipio was updated', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.nombre).to.eql('Updated Test Municipio');",
                  "    pm.expect(jsonData.departamento).to.eql('Updated Departamento');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "DELETE Municipio",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/municipios/{{testMunicipioId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "municipios", "{{testMunicipioId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains success message', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('message');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
